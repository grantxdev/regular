# Copy to .env.local and fill in from Supabase → Project Settings → API.
# Both values are public by design (protected by row-level security), so
# they are also set as GitHub repo *variables* for the Pages deploy.
# Leave these unset to run Regular in local-only mode (no login, browser storage).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
